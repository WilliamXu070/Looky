{
  "scenarios": [
    {
      "name": "measurement-multi-edge-details-cube-hole",
      "file": "testing/input/cube_hole.step",
      "actions": [
        {
          "kind": "setMeasurementUnit",
          "unit": "model",
          "mmPerModelUnit": 1.0,
          "durationMs": 40,
          "measurementExpect": {
            "kind": "empty",
            "entityCount": 0,
            "unitMode": "model"
          }
        },
        {
          "kind": "selectAt",
          "x": 0.5,
          "y": 0.5,
          "coordinateSpace": "normalizedViewport",
          "expect": {
            "kind": "edge"
          },
          "measurementExpect": {
            "kind": "edge",
            "entityCount": 1,
            "minTotalLength": 99.0,
            "maxTotalLength": 101.0,
            "unitMode": "model"
          },
          "durationMs": 100
        },
        {
          "kind": "selectAt",
          "x": 0.55,
          "y": 0.45,
          "coordinateSpace": "normalizedViewport",
          "modifiers": ["shift"],
          "expect": {
            "kind": "edge"
          },
          "measurementExpect": {
            "kind": "multiEdge",
            "entityCount": 2,
            "minTotalLength": 151.0,
            "maxTotalLength": 153.0,
            "minMinimumDistance": 0.0,
            "maxMinimumDistance": 0.001,
            "unitMode": "model"
          },
          "durationMs": 100
        },
        {
          "kind": "selectAt",
          "x": 0.55,
          "y": 0.45,
          "coordinateSpace": "normalizedViewport",
          "modifiers": ["command"],
          "expect": {
            "kind": "edge"
          },
          "measurementExpect": {
            "kind": "edge",
            "entityCount": 1,
            "minTotalLength": 99.0,
            "maxTotalLength": 101.0,
            "unitMode": "model"
          },
          "durationMs": 100
        }
      ]
    }
  ]
}
