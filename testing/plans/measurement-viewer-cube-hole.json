{
  "scenarios": [
    {
      "name": "measurement-viewer-cube-hole",
      "file": "testing/input/cube_hole.step",
      "actions": [
        { "kind": "wait", "label": "selection-index-ready", "durationMs": 120 },
        { "kind": "resetMeasurementScale", "label": "use-imported-step-units" },
        {
          "kind": "setMeasurementUnit",
          "label": "millimeters",
          "unit": "mm",
          "measurementExpect": { "kind": "empty", "entityCount": 0, "unitMode": "mm" }
        },
        {
          "kind": "setCamera",
          "label": "fixed-front-camera",
          "orientationDegrees": [0, 0, 0],
          "cameraPosition": [0, 0, 200],
          "fieldOfView": 45,
          "durationMs": 40
        },
        {
          "kind": "selectAt",
          "label": "single-top-edge",
          "x": 0.5,
          "y": 0.668,
          "coordinateSpace": "normalizedViewport",
          "expect": { "kind": "edge" },
          "measurementExpect": {
            "kind": "edge",
            "entityCount": 1,
            "minTotalLength": 50.7,
            "maxTotalLength": 50.9,
            "unitMode": "mm"
          },
          "durationMs": 60
        },
        {
          "kind": "selectAt",
          "label": "add-parallel-bottom-edge",
          "x": 0.5,
          "y": 0.332,
          "coordinateSpace": "normalizedViewport",
          "modifiers": ["shift"],
          "expect": { "kind": "edge" },
          "measurementExpect": {
            "kind": "multiEdge",
            "entityCount": 2,
            "relation": "parallel",
            "minTotalLength": 101.5,
            "maxTotalLength": 101.7,
            "unitMode": "mm"
          },
          "durationMs": 60
        },
        {
          "kind": "setMeasurementUnit",
          "label": "inches",
          "unit": "in",
          "measurementExpect": {
            "kind": "multiEdge",
            "entityCount": 2,
            "relation": "parallel",
            "minTotalLength": 3.99,
            "maxTotalLength": 4.01,
            "unitMode": "in"
          }
        },
        {
          "kind": "setMeasurementUnit",
          "label": "restore-millimeters",
          "unit": "mm",
          "measurementExpect": {
            "kind": "multiEdge",
            "entityCount": 2,
            "relation": "parallel",
            "unitMode": "mm"
          }
        },
        {
          "kind": "selectAt",
          "label": "replace-with-front-surface",
          "x": 0.6,
          "y": 0.58,
          "coordinateSpace": "normalizedViewport",
          "expect": {
            "kind": "surface",
            "surfaceTriangleCount": 67
          },
          "measurementExpect": {
            "kind": "surface",
            "entityCount": 1,
            "minArea": 1163.7,
            "maxArea": 1164.0,
            "minPerimeter": 192.1,
            "maxPerimeter": 192.5,
            "unitMode": "mm"
          },
          "durationMs": 60
        },
        {
          "kind": "selectAt",
          "label": "blank-clears",
          "x": 0.05,
          "y": 0.05,
          "coordinateSpace": "normalizedViewport",
          "expect": { "kind": "none" },
          "measurementExpect": { "kind": "empty", "entityCount": 0, "unitMode": "mm" },
          "durationMs": 60
        }
      ]
    }
  ]
}
