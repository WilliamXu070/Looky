#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_QUICKLOOK_PRECOMMIT:-0}" == "1" || "${SKIP_QUICKLOOK_PRECOMMIT:-0}" == "true" ]]; then
  exit 0
fi

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

echo "QuickLookStep pre-commit build guard: running make quicklook-commit-build"
make quicklook-commit-build
echo "QuickLookStep pre-commit build guard: build completed"
